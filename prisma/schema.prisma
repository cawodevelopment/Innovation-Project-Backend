// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  firstname    String
  lastname     String

  refreshTokens      RefreshToken[]
  recipes            Recipe[]
  userDietaryPreferences UserDietaryPreference[]
  userAllergens          userAllergen[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id                   String       @id @default(uuid())
  userId               String
  title                String
  status               RecipeStatus @default(DRAFT)
  instructions         String[]
  ingredients          String[]
  allergenNotices      String[]
  prepTimeInMinutes    Int
  cookingTimeInMinutes Int
  servings             Int
  dietaryRestrictions  String[]
  difficulty           String
  ratingOutOf5         Int

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nutritionInfo NutritionInfo? @relation("RecipeNutritionInfo")
}

model UserDietaryPreference {
  id     String @id @default(uuid())
  userId String
  dietaryPreferenceId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietaryPreference DietaryPreference @relation(fields: [dietaryPreferenceId], references: [id], onDelete: Cascade)
}

model DietaryPreference {
  id     String @id @default(uuid())
  name   String

  userDietaryPreferences UserDietaryPreference[]
}

model userAllergen {
  id         String @id @default(uuid())
  userId     String
  allergenId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergen Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)
}

model Allergen {
  id       String @id @default(uuid())
  name     String @unique

  userAllergens userAllergen[]
}

model NutritionInfo {
  id           String @id @default(uuid())
  recipeId     String @unique
  caloriesKcal Int
  proteinG     Int
  carbsG       Int
  fatG         Int

  recipe Recipe @relation("RecipeNutritionInfo", fields: [recipeId], references: [id], onDelete: Cascade)
}

enum RecipeStatus {
  DRAFT
  PUBLISHED
}
